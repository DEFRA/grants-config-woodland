npm run git:pre-commit-hook

branch="$(git symbolic-ref --short HEAD)"
currentUser="$(git config user.name)"

if [ "$currentUser" != "github-actions[bot]" ]; then

  if [ "$branch" = "main" ]; then
    echo "❌ Pushing to main is not allowed!"
    exit 1
  fi

  diffTarget="origin/HEAD"

  # For hotfix branches, compare against the remote branch if it exists.
  # Otherwise fall back to origin/HEAD for the initial push.
  if [[ "$branch" == hotfix-releases/* ]]; then
    if git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
      diffTarget="origin/$branch"
    fi
  fi

  if (
    git diff --name-only "$diffTarget...HEAD"
    git diff --cached --name-only
  ) | grep -q '^configurations/'; then
    if ! compgen -G ".changeset/*-*-*.md" > /dev/null; then
      echo "❌ Changes in configurations/ require a changeset"
      echo "Run: npm run version"
      exit 1
    fi
  fi
fi
