npm run git:pre-commit-hook

branch="$(git symbolic-ref --short HEAD)"
currentUser="$(git config user.name)"
if [ "$currentUser" != "github-actions[bot]" ]; then
    if [ "$branch" = "main" ]; then
      echo "❌ Pushing to main is not allowed!"
      exit 1
    fi
    if git diff --name-only origin/HEAD...HEAD | grep -q '^configurations/'; then
        if ! compgen -G ".changeset/*-*-*.md" > /dev/null; then
            echo "❌ Changes in configurations/ require a changeset"
            echo "Run: npm run version"
            exit 1
        fi
    fi
fi
