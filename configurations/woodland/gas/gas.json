        "$ref": "../schemas/woodland-application.schema.json",
        "if": {
          "properties": {
            "appLandHasExistingWmp": {
              "const": true
            }
          }
        },
        "then": {
          "required": ["existingWmps"],
          "properties": {
            "existingWmps": {
              "type": "string"
            }
          }
        },
        "else": {
          "properties": {
            "existingWmps": false
          }
        },
        "fgSumMax": {
          "fields": ["hectaresTenOrOverYearsOld", "hectaresUnderTenYearsOld"],
          "targetField": "totalHectaresForSelectedParcels"
        },
        "fgSumMin": {
          "fields": ["hectaresTenOrOverYearsOld", "hectaresUnderTenYearsOld"],
          "minimum": 0.5
        },
        "fgSumEquals": {
          "fields": ["landParcels[].areaHa"],
          "targetField": "totalHectaresForSelectedParcels"
        }
      },
