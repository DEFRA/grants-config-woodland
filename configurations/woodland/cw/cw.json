{
  "_id": {
    "$oid": "69c474992307ce057cfe6911"
  },
  "code": "woodland",
  "requiredRoles": {
    "allOf": ["ROLE_WMP"],
    "anyOf": []
  },
  "templates": {},
  "definitions": {
    "agreementsService": {
      "internalUrl": "https://fg-cw-frontend.dev.cdp-int.defra.cloud/agreement/{agreementRef}"
    }
  },
  "endpoints": [],
  "externalActions": [],
  "pages": {
    "cases": {
      "details": {
        "banner": {
          "title": {
            "text": "$.payload.answers.applicant.business.name",
            "type": "string"
          },
          "summary": {
            "scheme": {
              "label": "Scheme",
              "text": "$.payload.answers.scheme",
              "type": "string"
            },
            "applicationId": {
              "label": "Application ID",
              "text": "$.caseRef",
              "type": "string"
            },
            "sbi": {
              "label": "SBI",
              "text": "$.payload.identifiers.sbi",
              "type": "string"
            },
            "status": {
              "label": "Status",
              "text": "$.currentStatusName",
              "type": "string"
            }
          }
        },
        "tabs": {
          "agreements": {
            "link": {
              "id": "agreements",
              "href": {
                "urlTemplate": "/cases/{caseId}/agreements",
                "params": {
                  "caseId": "$._id"
                }
              },
              "text": "Agreements",
              "index": 2
            },
            "renderIf": "$.supplementaryData.agreements[0]",
            "content": [
              {
                "id": "title",
                "component": "heading",
                "text": "Funding agreement",
                "level": 2,
                "classes": "govuk-!-margin-top-6"
              },
              {
                "component": "summary-list",
                "rows": [
                  {
                    "label": "Agreement status",
                    "text": [
                      {
                        "component": "status",
                        "text": "jsonata:$sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt })[0].agreementStatus",
                        "themeMap": {
                          "OFFERED": "NOTICE",
                          "ACCEPTED": "INFO",
                          "AGREEMENT_DRAFTED": "INFO",
                          "AGREEMENT_GENERATING": "INFO",
                          "WITHDRAWN": "WARN",
                          "REJECTED": "ERROR"
                        },
                        "labelsMap": {
                          "AGREEMENT_GENERATING": "Agreement generating",
                          "AGREEMENT_DRAFTED": "Agreement drafted",
                          "OFFERED": "Offered",
                          "ACCEPTED": "Accepted",
                          "WITHDRAWN": "Withdrawn",
                          "REJECTED": "Rejected"
                        }
                      }
                    ]
                  },
                  {
                    "label": "Reference",
                    "text": "jsonata:$sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt })[0].agreementRef"
                  },
                  {
                    "label": "Date created",
                    "text": "jsonata:$sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt })[0].createdAt",
                    "format": "formatDate"
                  },
                  {
                    "label": "Date accepted",
                    "text": "jsonata:$sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt })[0].agreementStatus = 'ACCEPTED' ? $formatTime($toMillis($sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt })[0].acceptedAt), '[D] [MNn] [Y]') : 'Not accepted'"
                  },
                  {
                    "label": "Start date",
                    "text": "jsonata:$sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt })[0].startDate ? $formatTime($toMillis($sort($.supplementaryData.agreements,function($l, $r) { $l.createdAt < $r.createdAt })[0].startDate), '[D] [MNn] [Y]') : 'Not started'"
                  },
                  {
                    "label": "View",
                    "text": [
                      {
                        "component": "url",
                        "text": "View agreement",
                        "href": {
                          "urlTemplate": "$.definitions.agreementsService.internalUrl",
                          "params": {
                            "agreementRef": "jsonata:$sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt })[0].agreementRef"
                          }
                        },
                        "target": "_blank",
                        "rel": "noopener"
                      }
                    ]
                  }
                ]
              },
              {
                "component": "conditional",
                "condition": "jsonata:$count($.supplementaryData.agreements) > 1",
                "whenTrue": {
                  "component": "container",
                  "items": [
                    {
                      "id": "version-history-title",
                      "component": "heading",
                      "text": "Version history",
                      "level": 3,
                      "classes": "govuk-!-margin-top-6"
                    },
                    {
                      "type": "array",
                      "component": "table",
                      "rowsRef": "jsonata:$filter($sort($.supplementaryData.agreements, function($l, $r) { $l.createdAt < $r.createdAt }), function($v, $i) { $i > 0 })",
                      "rows": [
                        {
                          "label": "Reference",
                          "text": "@.agreementRef"
                        },
                        {
                          "label": "Date",
                          "text": "@.createdAt",
                          "format": "formatDate"
                        },
                        {
                          "label": "Status",
                          "component": "status",
                          "text": "@.agreementStatus",
                          "themeMap": {
                            "OFFERED": "NOTICE",
                            "ACCEPTED": "INFO",
                            "AGREEMENT_DRAFTED": "INFO",
                            "AGREEMENT_GENERATING": "INFO",
                            "WITHDRAWN": "WARN",
                            "REJECTED": "ERROR"
                          },
                          "labelsMap": {
                            "AGREEMENT_GENERATING": "Agreement generating",
                            "AGREEMENT_DRAFTED": "Agreement drafted",
                            "OFFERED": "Offered",
                            "ACCEPTED": "Accepted",
                            "WITHDRAWN": "Withdrawn",
                            "REJECTED": "Rejected"
                          }
                        },
                        {
                          "label": "",
                          "component": "url",
                          "text": "View this version",
                          "href": {
                            "urlTemplate": "$.definitions.agreementsService.internalUrl",
                            "params": {
                              "agreementRef": "@.agreementRef"
                            }
                          },
                          "target": "_blank",
                          "rel": "noopener"
                        }
                      ]
                    }
                  ]
                }
              }
            ]
          }
        }
      }
    }
  },
  "phases": [
    {
      "code": "PHASE_PRE_AWARD",
      "name": "Pre-award",
      "stages": [
        {
          "code": "STAGE_REVIEWING_APPLICATION",
          "name": "Reviewing Application",
          "description": "Review the woodland management plan application",
          "statuses": [
            {
              "code": "STATUS_APPLICATION_RECEIVED",
              "name": "Application Received",
              "theme": "NEUTRAL",
              "description": "Application received and pending review",
              "interactive": false,
              "transitions": [
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_REVIEWING_APPLICATION:STATUS_IN_REVIEW",
                  "checkTasks": false,
                  "action": {
                    "code": "ACTION_START",
                    "name": "Start",
                    "checkTasks": false,
                    "comment": null
                  }
                }
              ]
            },
            {
              "code": "STATUS_IN_REVIEW",
              "name": "In Review",
              "theme": "INFO",
              "description": "Application is being reviewed",
              "interactive": true,
              "transitions": [
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_AWAITING_FC:STATUS_AWAITING_FC_REVIEW",
                  "checkTasks": true,
                  "action": {
                    "code": "ACTION_ASSIGN_TO_FC",
                    "name": "Assign to Forestry Commission",
                    "checkTasks": true,
                    "comment": {
                      "label": "Explain this decision",
                      "helpText": "You must include an explanation for auditing purposes.",
                      "mandatory": true
                    }
                  }
                }
              ]
            }
          ],
          "taskGroups": [
            {
              "code": "MANUAL_REVIEW_TASKS",
              "name": "Application review tasks",
              "description": "Tasks to be completed during the initial review of the application",
              "tasks": [
                {
                  "code": "TASK_CREATED_CRM_RECORD",
                  "name": "Created CRM record",
                  "mandatory": true,
                  "description": [
                    {
                      "component": "heading",
                      "text": "Created CRM record",
                      "level": 2,
                      "classes": "govuk-!-margin-bottom-3"
                    },
                    {
                      "component": "paragraph",
                      "text": "Confirm that a CRM record has been created for this application.",
                      "classes": "govuk-!-margin-bottom-6"
                    }
                  ],
                  "statusOptions": [
                    {
                      "code": "NOT_DONE",
                      "name": "Not done",
                      "theme": "NOTICE",
                      "altName": "Not done",
                      "completes": false
                    },
                    {
                      "code": "DONE",
                      "name": "Done",
                      "theme": "NONE",
                      "altName": "Done",
                      "completes": true
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "code": "STAGE_AWAITING_FC",
          "name": "Awaiting Forestry Commission",
          "description": "Awaiting Forestry Commission review of the application",
          "statuses": [
            {
              "code": "STATUS_AWAITING_FC_REVIEW",
              "name": "Awaiting FC Review",
              "theme": "INFO",
              "description": "Application is awaiting Forestry Commission review",
              "interactive": true,
              "transitions": [
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_AWAITING_FC:STATUS_AGREEMENT_GENERATING",
                  "checkTasks": true,
                  "action": {
                    "code": "ACTION_APPROVE_FOR_FC",
                    "name": "Approve",
                    "checkTasks": true,
                    "comment": {
                      "label": "Explain this decision",
                      "helpText": "You must include an explanation for auditing purposes.",
                      "mandatory": true
                    }
                  }
                },
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_AWAITING_FC:STATUS_REJECTED_BY_FC",
                  "checkTasks": false,
                  "action": {
                    "code": "ACTION_REJECT_FOR_FC",
                    "name": "Reject",
                    "checkTasks": false,
                    "comment": {
                      "label": "Explain this decision",
                      "helpText": "You must include an explanation for auditing purposes.",
                      "mandatory": true
                    }
                  }
                }
              ]
            },
            {
              "code": "STATUS_AGREEMENT_GENERATING",
              "name": "Agreement Generating",
              "theme": "NEUTRAL",
              "description": "Agreement is being generated",
              "interactive": false,
              "transitions": [
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_AGREEMENT_GENERATED:STATUS_AGREEMENT_GENERATED",
                  "checkTasks": false,
                  "action": null
                }
              ]
            },
            {
              "code": "STATUS_REJECTED_BY_FC",
              "name": "Rejected by FC",
              "theme": "ERROR",
              "description": "Application has been rejected by the Forestry Commission",
              "interactive": false,
              "transitions": []
            }
          ],
          "taskGroups": [
            {
              "code": "FC_REVIEW_TASKS",
              "name": "FC review tasks",
              "description": "Tasks to be completed during the Forestry Commission review",
              "tasks": [
                {
                  "code": "TASK_FC_APPROVED",
                  "name": "FC approved",
                  "mandatory": true,
                  "description": [
                    {
                      "component": "heading",
                      "text": "FC approved",
                      "level": 2,
                      "classes": "govuk-!-margin-bottom-3"
                    },
                    {
                      "component": "paragraph",
                      "text": "Confirm that the Forestry Commission has approved this application.",
                      "classes": "govuk-!-margin-bottom-6"
                    }
                  ],
                  "statusOptions": [
                    {
                      "code": "NO",
                      "name": "No",
                      "theme": "NOTICE",
                      "altName": "No",
                      "completes": false
                    },
                    {
                      "code": "YES",
                      "name": "Yes",
                      "theme": "NONE",
                      "altName": "Yes",
                      "completes": true
                    }
                  ]
                },
                {
                  "code": "TASK_FC_RESPONSE_MATCHES_APPLICATION",
                  "name": "FC response matches application",
                  "mandatory": true,
                  "description": [
                    {
                      "component": "heading",
                      "text": "FC response matches application",
                      "level": 2,
                      "classes": "govuk-!-margin-bottom-3"
                    },
                    {
                      "component": "paragraph",
                      "text": "Confirm that the Forestry Commission response matches the application details.",
                      "classes": "govuk-!-margin-bottom-6"
                    }
                  ],
                  "statusOptions": [
                    {
                      "code": "NO",
                      "name": "No",
                      "theme": "NOTICE",
                      "altName": "No",
                      "completes": false
                    },
                    {
                      "code": "YES",
                      "name": "Yes",
                      "theme": "NONE",
                      "altName": "Yes",
                      "completes": true
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "code": "STAGE_AGREEMENT_GENERATED",
          "name": "Agreement Generated",
          "description": "Agreement has been generated by the Agreements Service",
          "statuses": [
            {
              "code": "STATUS_AGREEMENT_GENERATED",
              "name": "Agreement Generated",
              "theme": "SUCCESS",
              "description": "The agreement has been generated by the Agreements Service",
              "interactive": false,
              "transitions": [
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_SENDING_AGREEMENT:STATUS_AWAITING_SEND_AGREEMENT",
                  "checkTasks": false,
                  "action": null
                }
              ]
            }
          ],
          "taskGroups": []
        },
        {
          "code": "STAGE_SENDING_AGREEMENT",
          "name": "Sending Agreement",
          "description": "Agreement has been generated and is ready to send to the customer",
          "statuses": [
            {
              "code": "STATUS_AWAITING_SEND_AGREEMENT",
              "name": "Awaiting Send Agreement",
              "theme": "INFO",
              "description": "Agreement is ready to be sent to the customer",
              "interactive": true,
              "transitions": [
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_SENDING_AGREEMENT:STATUS_AGREEMENT_WITH_CUSTOMER",
                  "checkTasks": true,
                  "action": {
                    "code": "ACTION_SEND_AGREEMENT",
                    "name": "Send Agreement",
                    "checkTasks": true,
                    "comment": null
                  }
                }
              ]
            },
            {
              "code": "STATUS_AGREEMENT_WITH_CUSTOMER",
              "name": "Agreement With Customer",
              "theme": "INFO",
              "description": "Agreement has been sent to the customer for review",
              "interactive": false,
              "transitions": [
                {
                  "targetPosition": "PHASE_MONITORING:STAGE_MONITORING:STATUS_AGREEMENT_ACCEPTED",
                  "checkTasks": false,
                  "action": null
                },
                {
                  "targetPosition": "PHASE_PRE_AWARD:STAGE_REJECTED_BY_APPLICANT:STATUS_REJECTED_BY_APPLICANT",
                  "checkTasks": false,
                  "action": null
                }
              ]
            }
          ],
          "taskGroups": [
            {
              "code": "SEND_AGREEMENT_TASKS",
              "name": "Send agreement tasks",
              "description": "Tasks to be completed before sending the agreement to the customer",
              "tasks": [
                {
                  "code": "TASK_AGREEMENT_SENT",
                  "name": "Agreement sent",
                  "mandatory": true,
                  "description": [
                    {
                      "component": "heading",
                      "text": "Agreement sent",
                      "level": 2,
                      "classes": "govuk-!-margin-bottom-3"
                    },
                    {
                      "component": "paragraph",
                      "text": "Confirm that the agreement has been sent to the customer.",
                      "classes": "govuk-!-margin-bottom-6"
                    }
                  ],
                  "statusOptions": [
                    {
                      "code": "NOT_SENT",
                      "name": "Not sent",
                      "theme": "NOTICE",
                      "altName": "Not sent",
                      "completes": false
                    },
                    {
                      "code": "SENT",
                      "name": "Sent",
                      "theme": "NONE",
                      "altName": "Sent",
                      "completes": true
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "code": "STAGE_REJECTED_BY_APPLICANT",
          "name": "Rejected by Applicant",
          "description": "Application has been rejected by the applicant",
          "statuses": [
            {
              "code": "STATUS_REJECTED_BY_APPLICANT",
              "name": "Rejected by Applicant",
              "theme": "ERROR",
              "description": "The applicant has rejected the agreement offer",
              "interactive": false,
              "transitions": []
            }
          ],
          "taskGroups": []
        }
      ]
    },
    {
      "code": "PHASE_MONITORING",
      "name": "Monitoring",
      "stages": [
        {
          "code": "STAGE_MONITORING",
          "name": "Monitoring",
          "description": "Agreement monitoring",
          "statuses": [
            {
              "code": "STATUS_AGREEMENT_ACCEPTED",
              "name": "Agreement Accepted",
              "theme": "SUCCESS",
              "description": "Customer has accepted the agreement",
              "interactive": false,
              "transitions": []
            }
          ],
          "taskGroups": []
        }
      ]
    }
  ]
}
